{
  "name": "newsdash",
  "displayName": "NewsDash",
  "description": "Technology Control Center for VS Code — live news, markets, critical alerts, AI chat, and daily summaries.",
  "version": "1.2.1",
  "publisher": "usmanyousaaf",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "news",
    "dashboard",
    "ai",
    "crypto",
    "markets",
    "intelligence",
    "control center",
    "briefing"
  ],
  "galleryBanner": {
    "color": "#0b0d12",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/osmanyousaaf/news-dashboard.git"
  },
  "homepage": "https://github.com/osmanyousaaf/news-dashboard",
  "bugs": {
    "url": "https://github.com/osmanyousaaf/news-dashboard/issues"
  },
  "license": "MIT",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "icon": "media/icon.png",
  "contributes": {
    "commands": [
      {
        "command": "newsdash.openDashboard",
        "title": "Open Dashboard",
        "category": "NewsDash",
        "icon": {
          "light": "media/icon.png",
          "dark": "media/icon.png"
        }
      },
      {
        "command": "newsdash.refresh",
        "title": "Refresh Feeds",
        "category": "NewsDash"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "newsdash",
          "title": "NewsDash",
          "icon": "media/activity-bar.svg"
        }
      ]
    },
    "views": {
      "newsdash": [
        {
          "type": "webview",
          "id": "newsdash.sidebar",
          "name": "Control Center",
          "contextualTitle": "NewsDash"
        }
      ]
    },
    "configuration": {
      "title": "NewsDash",
      "properties": {
        "newsdash.apiBaseUrl": {
          "type": "string",
          "default": "https://news-dashboard-e69n.vercel.app",
          "markdownDescription": "Base URL for the NewsDash intelligence API (no trailing slash). Used for news, markets, weather, chat, and summaries."
        },
        "newsdash.refreshInterval": {
          "type": "number",
          "default": 60,
          "minimum": 0,
          "markdownDescription": "How often the dashboard refreshes live data, in seconds. Set to `0` to turn auto-refresh off."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run compile:ext && npm run compile:webview",
    "compile:ext": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "compile:webview": "npm run build --prefix webview-ui",
    "watch": "npm run compile:ext -- --watch",
    "package": "vsce package --no-dependencies",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0"
  }
}
